# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/your-db-name
MONGODB_TEST_URI=mongodb://localhost:27017/your-db-test-name

# JWT Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=7d

# Ghaymah TTS Configuration
# ElevenLabs TTS
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id

GHAYMAH_API_URL=https://arabic-tts-1-52149f99.hosted.cumin.dev/v1/audio/speech
GHAYMAH_API_KEY=your-ghaymah-key
GHAYMAH_VOICE_ID=your-voice-id

# Google Cloud Text-to-Speech
GOOGLE_APPLICATION_CREDENTIALS=./path/to/google-credentials.json
GOOGLE_PROJECT_ID=your-project-id

# Azure Cognitive Services
AZURE_TTS_KEY=your-azure-key
AZURE_TTS_REGION=your-region

# AWS Polly
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# File Upload Limits
MAX_FILE_SIZE_MB=50
MAX_AUDIO_SIZE_MB=10

# AI Model Configuration
AI_MODEL_PATH=./ai/models/gesture-model.json
AI_MODEL_TYPE=tensorflow
# or AI_MODEL_TYPE=onnx
PREDICTION_THRESHOLD=0.7

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Bluetooth (Optional)
BLUETOOTH_ENABLED=false
GLOVE_DEVICE_NAME=SmartGlove

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key

# Hugging Face Configuration
HUGGINGFACE_API_TOKEN=your-huggingface-token
HUGGINGFACE_MODEL_ID=CohereLabs/c4ai-command-r7b-arabic-02-2025

